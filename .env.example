# MongoDB Atlas connection string
# Get one free at: https://www.mongodb.com/cloud/atlas (M0 free tier is enough)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/fly91?retryWrites=true&w=majority

# Admin authentication (basic — for demo only)
ADMIN_TOKEN=change-me-to-a-real-secret

# Node environment
NODE_ENV=development
